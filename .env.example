# LLM — choose one (leave blank to use no-llm mode)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local LLM, default host)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# NewsAPI (100 req/day free) — https://newsapi.org
NEWSAPI_KEY=

# Telegram notifications — https://core.telegram.org/bots
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=          # obtenu via @BotFather → /newbot
TELEGRAM_CHAT_ID=            # ton chat_id (getUpdates après /start au bot)
TELEGRAM_MARKET_ALERTS=false
TELEGRAM_ALERT_THRESHOLD=5.0

# Storage
DB_PATH=data/processed/briefings.db
RAW_DIR=data/raw
PROCESSED_DIR=data/processed

# Briefing settings
LOOKBACK_HOURS=24
MAX_ARTICLES_PER_SOURCE=20
MIN_RELEVANCE_SCORE=0.3
